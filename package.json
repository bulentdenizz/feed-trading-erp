    "better-sqlite3": "^12.9.0",
    "i18next": "^26.0.4",
    "lucide-react": "^1.8.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-i18next": "^17.0.2",
    "react-router-dom": "^7.14.2",
    "recharts": "^3.8.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config": "^2.1.0",
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
