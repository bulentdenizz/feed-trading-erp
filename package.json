    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "postcss": "^8.5.9",
    "prettier": "^3.7.4",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.7.0",
    "vite": "^7.2.6"
